// CNOS 用户态 int $0x80 号 — 须与 kernel/syscall_abi.h 中 CNOS_SYS_* 一致（见 user/SYSCALL-ABI.txt）

const SYS_EXIT          = 0
const SYS_WRITE         = 1
const SYS_GETPID        = 2
const SYS_READ          = 3
const SYS_UPTIME_TICKS  = 4
const SYS_OPEN          = 5
const SYS_CLOSE         = 6

// 与 kernel/syscall_abi.h 中 CNOS_SYSCALL_MAX_IO_BYTES 一致（单次 read/write 长度上限）
const CNOS_MAX_WRITE_BYTES = 1048576
